 
// Conversione lat/lon → tile coordinates (standard Web Mercator)
int lon_to_tile_x(double lon, int zoom) {
    return static_cast<int>(
        std::floor((lon + 180.0) / 360.0 * (1 << zoom))
    );
}

int lat_to_tile_y(double lat, int zoom) {
    double lat_rad = lat * M_PI / 180.0;
    return static_cast<int>(
        std::floor((1.0 - std::log(std::tan(lat_rad) + 1.0 / std::cos(lat_rad)) / M_PI) / 2.0 * (1 << zoom))
    );
}
```

